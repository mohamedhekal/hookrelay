{
    "name": "mohamedmohamedhekal/hookrelay",
    "description": "Reliable webhook delivery for Laravel: HMAC signing, retries, dead-letter queues, and replay",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "webhooks",
        "retries",
        "hmac",
        "dead-letter",
        "saas",
        "php",
        "laravel-package",
        "webhook",
        "outbound-webhooks",
        "signature"
    ],
    "authors": [
        {
            "name": "Mohamed Hekal"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "laravel/pint": "^1.18",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Hekal\\HookRelay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hekal\\HookRelay\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hekal\\HookRelay\\HookRelayServiceProvider"
            ],
            "aliases": {
                "HookRelay": "Hekal\\HookRelay\\Facades\\HookRelay"
            }
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse --memory-limit=512M",
        "format": "pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "homepage": "https://github.com/mohamedmohamedhekal/hookrelay",
    "support": {
        "issues": "https://github.com/mohamedmohamedhekal/hookrelay/issues",
        "source": "https://github.com/mohamedmohamedhekal/hookrelay"
    }
}
